    {
      "parameters": {
        "promptType": "define",
        "text": "=CURRENT INQUIRY:\nClient: {{ $json.client_name }} ({{ $json.client_email }})\nBuilding: {{ $json.building_name }} ({{ $json.building_size }} units)\nMessage: {{ $json.inquiry_message }}\n\nCLIENT CONTEXT:\n{{ JSON.stringify($json.client_context, null, 2) }}\n\nSIMILAR PAST INQUIRIES (RAG):\n{{ JSON.stringify($json.similar_cases, null, 2) }}\n\nINSTRUCTIONS:\nAnalyze this strata consultancy inquiry and provide a structured response.\n\nClassification Rules:\n- \"New Client\" if client_context.client_exists is false\n- \"Support Request\" if existing client with active projects\n- \"Complaint\" if negative sentiment detected (dissatisfaction, unhappy, issues, problems)\n- \"General Question\" for informational inquiries\n\nUrgency Levels:\n- \"High\" for complaints, urgent issues, or time-sensitive matters\n- \"Medium\" for support requests from existing clients\n- \"Low\" for general questions or new client inquiries\n\nReturn a JSON object with:\n- client_type: \"New Client\" or \"Existing Client\"\n- category: classification from rules above\n- urgency: \"High\", \"Medium\", or \"Low\"\n- confidence: 0-100 (your confidence in the classification)\n- summary: brief 1-sentence summary of the inquiry\n- recommended_actions: array of 2-4 specific action items for staff\n- historical_reference: { similar_case_id, previous_resolution } from RAG data if relevant\n- suggested_response: professional response draft for the client (2-3 paragraphs)\n- requires_human_review: true if confidence < 70 or urgency is High",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an AI operations assistant for a strata consultancy. Analyze inquiries using client context and historical data to classify, prioritize, and recommend actions. Be professional, empathetic, and leverage past successful resolutions."
        }
      },
      "id": "ef8b4d2c-000b-4425-852a-1f9f7db884e6",
      "name": "Classify & Analyze Inquiry",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1136,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "combinator": "or",
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "1",
              "leftValue": "={{ $json.output.urgency }}",
              "rightValue": "High",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "2",
              "leftValue": "={{ $json.output.requires_human_review }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ]
        },
        "options": {}
      },
